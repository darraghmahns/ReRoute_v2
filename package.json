{
  "name": "reroute",
  "version": "1.0.0",
  "description": "AI-Powered Cycling Training Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ./venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8002",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && poetry install",
    "build": "cd frontend && npm run build",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "cycling",
    "training",
    "ai",
    "routes",
    "strava"
  ],
  "author": "Darragh Mahns",
  "license": "MIT",
  "dependencies": {
    "react-markdown": "^10.1.0"
  }
}
